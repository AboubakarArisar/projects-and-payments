# ------------------------------------------------------------------
# Frontend environment config (Vite)
# Copy this file to ".env" (dev) and/or ".env.production" (prod build):
#   cp .env.example .env
# Vite only exposes vars prefixed with VITE_ to the app.
# ------------------------------------------------------------------

# Base URL of the backend API.
# Dev (local backend):
VITE_API_URL=http://localhost:5000

# Production example (set this in .env.production or your host, e.g. Vercel):
# VITE_API_URL=https://eldt-project-bcea9fba4bba.herokuapp.com
